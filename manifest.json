{
  "manifest_version": 3,
  "name": "WaitMate",
  "version": "1.0",
  "description": "WaitMate replaces boring blank loading screens with witty AI thinking messages and a premium dark overlay.",
  "permissions": [],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "128": "icon.png"
  }
}
